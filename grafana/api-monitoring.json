        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "signal_collector_signals_count",
          "legendFormat": "{{collector}}",
          "refId": "A"
        }
      ],
      "title": "Collector Signal Count",
      "type": "timeseries"
    },
    {
      "collapsed": false,
